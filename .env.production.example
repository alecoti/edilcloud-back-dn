APP_ENV=production
DJANGO_SETTINGS_MODULE=edilcloud.settings.prod
DEBUG=false
SECRET_KEY=replace-me-with-a-long-random-secret
TIME_ZONE=Europe/Rome

ALLOWED_HOSTS=back.edilcloud.eu,194.163.149.254,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://app.edilcloud.eu
CSRF_TRUSTED_ORIGINS=https://back.edilcloud.eu,https://app.edilcloud.eu

APP_FRONTEND_URL=https://app.edilcloud.eu
BACKEND_PUBLIC_URL=https://back.edilcloud.eu
MARKETING_SITE_URL=https://www.edilcloud.eu
PAYMENTS_SITE_URL=https://payments.edilcloud.eu

POSTGRES_DB=edilcloud_dn
POSTGRES_USER=edilcloud_dn
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://edilcloud_dn:replace-me@db:5432/edilcloud_dn

REDIS_URL=redis://redis:6379/0
CACHE_KEY_PREFIX=edilcloud-dn
CACHE_DEFAULT_TIMEOUT_SECONDS=300
REALTIME_CHANNEL_CAPACITY=1500
REALTIME_CHANNEL_EXPIRY_SECONDS=60
REALTIME_TICKET_TTL_SECONDS=90

BACKEND_BIND_IP=127.0.0.1
BACKEND_BLUE_PORT=18001
BACKEND_GREEN_PORT=18002
GUNICORN_WORKERS=4

WORDPRESS_DB_NAME=edilcloud_wp
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=replace-me
WORDPRESS_DB_ROOT_PASSWORD=replace-me
WORDPRESS_DB_BIND_IP=0.0.0.0
WORDPRESS_DB_PORT=3307
WORDPRESS_DB_HOST=194.163.149.254:3307

SENTRY_DSN=
OPENAI_API_KEY=replace-me
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_DRAFT_MODEL=gpt-4o-mini
AI_ASSISTANT_MONTHLY_TOKEN_LIMIT=100000
AI_ASSISTANT_EMBEDDING_MODEL=text-embedding-3-large
AI_ASSISTANT_RETRIEVAL_TOP_K=12
AI_ASSISTANT_CONTEXT_SOURCE_LIMIT=8
AI_ASSISTANT_CHUNK_TARGET_CHARS=1100
AI_ASSISTANT_CHUNK_OVERLAP_CHARS=180
AI_ASSISTANT_MAX_CHUNKS_PER_SOURCE=24
AI_ASSISTANT_EMBEDDING_BATCH_SIZE=16
AI_ASSISTANT_EMBEDDING_CACHE_TTL_SECONDS=86400
AI_ASSISTANT_EMBEDDING_DIMENSIONS=3072
ASSISTANT_INDEXER_POLL_SECONDS=10
ASSISTANT_INDEXER_BATCH_SIZE=4

AUTH_ACCESS_CODE_TTL_SECONDS=600
AUTH_ONBOARDING_SESSION_TTL_SECONDS=1800
AUTH_ACCESS_CODE_RESEND_COOLDOWN_SECONDS=60
AUTH_ACCESS_CODE_MAX_ATTEMPTS=5
AUTH_INCLUDE_DEBUG_CODES=false
ENABLE_DEV_BOOTSTRAP_AUTH=false

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
EMAIL_DELIVERY_MODE=threaded
EMAIL_THREAD_POOL_SIZE=2
DEFAULT_FROM_EMAIL=your-email@gmail.com
REGISTRATION_FROM_EMAIL=your-email@gmail.com
SERVER_EMAIL=your-email@gmail.com

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

FCM_PUSH_ENABLED=false
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=
FCM_ANDROID_CHANNEL_ID=edilcloud_notifications

PROJECT_ARCHIVE_AFTER_DAYS=365
PROJECT_PURGE_AFTER_ARCHIVE_DAYS=180

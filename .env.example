APP_ENV=local
DJANGO_SETTINGS_MODULE=edilcloud.settings.local
SECRET_KEY=change-me
DEBUG=true
TIME_ZONE=Europe/Rome
APP_VERSION=0.1.0-dev
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edilcloud_dn
REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=edilcloud-dn
CACHE_DEFAULT_TIMEOUT_SECONDS=300
REALTIME_CHANNEL_CAPACITY=1500
REALTIME_CHANNEL_EXPIRY_SECONDS=60
REALTIME_TICKET_TTL_SECONDS=90
SENTRY_DSN=
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_DRAFT_MODEL=gpt-4o-mini
AI_ASSISTANT_MONTHLY_TOKEN_LIMIT=100000
AI_ASSISTANT_EMBEDDING_MODEL=text-embedding-3-large
AI_ASSISTANT_RETRIEVAL_TOP_K=12
AI_ASSISTANT_CONTEXT_SOURCE_LIMIT=8
AI_ASSISTANT_CHUNK_TARGET_CHARS=1100
AI_ASSISTANT_CHUNK_OVERLAP_CHARS=180
AI_ASSISTANT_MAX_CHUNKS_PER_SOURCE=24
AI_ASSISTANT_EMBEDDING_BATCH_SIZE=16
AI_ASSISTANT_EMBEDDING_CACHE_TTL_SECONDS=86400
AI_ASSISTANT_EMBEDDING_DIMENSIONS=3072
ASSISTANT_INDEXER_POLL_SECONDS=10
ASSISTANT_INDEXER_BATCH_SIZE=4
GEOCODING_PROVIDER=nominatim
GEOCODING_TIMEOUT_SECONDS=4
GEOCODING_USER_AGENT=EdilCloud/0.1.0-dev (local-dev geocoding)
GEOCODING_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
LOG_LEVEL=INFO
LOG_FORMAT=console
APP_FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8001
DEFAULT_FROM_EMAIL=no-reply@edilcloud.local
SERVER_EMAIL=no-reply@edilcloud.local
REGISTRATION_FROM_EMAIL=registration@edilcloud.io
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.edilcloud.io
EMAIL_PORT=587
EMAIL_HOST_USER=notification@edilcloud.io
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
EMAIL_DELIVERY_MODE=threaded
EMAIL_THREAD_POOL_SIZE=2
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_ACCESS_CODE_TTL_SECONDS=600
AUTH_ONBOARDING_SESSION_TTL_SECONDS=1800
AUTH_ACCESS_CODE_RESEND_COOLDOWN_SECONDS=60
AUTH_ACCESS_CODE_MAX_ATTEMPTS=5
AUTH_PASSWORD_RESET_TTL_SECONDS=900
AUTH_PASSWORD_RESET_MAX_ATTEMPTS=5
AUTH_PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
AUTH_TOKEN_ISSUER=edilcloud-back-dn
AUTH_TOKEN_AUDIENCE=edilcloud-web
AUTH_REFRESH_TOKEN_AUDIENCE=edilcloud-web-refresh
AUTH_INCLUDE_DEBUG_CODES=false
ENABLE_DEV_BOOTSTRAP_AUTH=false
PROJECT_ARCHIVE_AFTER_DAYS=365
PROJECT_PURGE_AFTER_ARCHIVE_DAYS=180
